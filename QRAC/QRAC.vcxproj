std::string nativeOpenFolderDialog() {
#ifdef _WIN32
    char buf[MAX_PATH * 4] = {};
    BROWSEINFOA bi = {};
    bi.lpszTitle = "Select folder containing files to encode";
    bi.ulFlags = BIF_RETURNONLYFSDIRS | BIF_NEWDIALOGSTYLE;
    LPITEMIDLIST pidl = SHBrowseForFolderA(&bi);
